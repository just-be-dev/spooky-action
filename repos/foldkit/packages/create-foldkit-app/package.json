{
  "name": "create-foldkit-app",
  "version": "0.12.4",
  "description": "Create Foldkit applications",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-foldkit-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "clean": "rimraf dist *.tsbuildinfo",
