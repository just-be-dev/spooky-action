{
  "name": "pinch-click",
  "source": "hand",
  "metrics": {
    "pinch": "dist(world_thumb_tip, world_index_tip) / dist(world_wrist, world_middle_mcp)",
    "pos": { "expr": "mid(thumb_tip, index_tip)", "smooth": 0.4 }
  },
  "initial": "idle",
  "states": {
    "idle": {
      "on": [{ "if": "pinch < 0.9", "goto": "track" }]
    },
    "track": {
      "emit": {
        "type": "circle",
        "x": "pos.x",
        "y": "pos.y",
        "r": "lerp(pinch, 0.35, 0.9, 8, 64)"
      },
      "on": [
        {
          "if": "pinch < 0.35 && hands.count == 1",
          "goto": "fired",
          "emit": { "type": "click", "x": "pos.x", "y": "pos.y" }
        },
        { "if": "pinch > 0.9", "goto": "idle", "emit": { "type": "hide" } }
      ]
    },
    "fired": {
      "emit": { "type": "circle", "x": "pos.x", "y": "pos.y", "r": 8 },
      "on": [{ "if": "pinch > 0.5", "goto": "track" }]
    }
  },
  "onLost": { "emit": { "type": "hide" } }
}
