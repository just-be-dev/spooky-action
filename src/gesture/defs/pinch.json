{
  "name": "pinch",
  "source": "hand",
  "metrics": {
    "pinch": "dist2d(thumb_tip, index_tip) / dist2d(wrist, middle_mcp)",
    "pos": { "expr": "mid(thumb_tip, index_tip)", "smooth": 0.4 }
  },
  "initial": "off",
  "states": {
    "off": {
      "on": [{ "if": "pinch < 0.9", "goto": "potential" }]
    },
    "potential": {
      "on": [
        { "if": "pinch < 0.35", "goto": "active" },
        { "if": "pinch > 0.9", "goto": "off" }
      ]
    },
    "active": {
      "on": [{ "if": "pinch > 0.45", "goto": "potential" }]
    }
  }
}
