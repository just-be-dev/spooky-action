{
  "name": "mouth-ring",
  "source": "face",
  "metrics": {
    "open": "dist(upper_lip, lower_lip) / dist(forehead, chin)",
    "pos": { "expr": "nose_tip", "smooth": 0.5 }
  },
  "initial": "idle",
  "states": {
    "idle": {
      "on": [{ "if": "open > 0.08", "goto": "showing" }]
    },
    "showing": {
      "emit": {
        "type": "circle",
        "x": "pos.x",
        "y": "pos.y",
        "r": "lerp(open, 0.05, 0.2, 12, 60)"
      },
      "on": [{ "if": "open < 0.05", "goto": "idle", "emit": { "type": "hide" } }]
    }
  },
  "onLost": { "emit": { "type": "hide" } }
}
