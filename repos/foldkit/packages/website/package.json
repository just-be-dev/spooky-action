{
  "name": "website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter foldkit docs",
    "dev": "vite",
    "prebuild": "pnpm --filter foldkit docs",
    "build": "vite build",
    "preview": "vite preview",
    "pretypecheck": "pnpm --filter foldkit docs",
    "typecheck": "tsc --noEmit",
    "format": "prettier -w .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "prerender": "tsx scripts/prerender.ts",
    "postprerender": "pagefind",
    "preview:search": "pnpm build && pnpm prerender && vite preview"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.66",
    "@tailwindcss/vite": "^4.2.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@webcontainer/api": "^1.6.4",
    "clsx": "^2.1.1",
    "effect": "4.0.0-beta.66",
    "foldkit": "workspace:*",
    "monaco-editor": "^0.55.1",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.66",
    "@eslint/js": "^10.0.1",
    "@foldkit/vite-plugin": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "pagefind": "^1.5.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "satori": "^0.26.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
